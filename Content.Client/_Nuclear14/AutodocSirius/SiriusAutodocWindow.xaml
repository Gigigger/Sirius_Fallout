<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'autodoc-window-title'}"
               MinSize="600 620"
               SetSize="600 620">
    <BoxContainer Orientation="Vertical" Margin="10">
        <!-- Header -->
        <Label Name="HeaderLabel"
               Text="{Loc 'autodoc-header'}"
               FontColorOverride="#33FF33"
               StyleClasses="monospace"
               HorizontalAlignment="Center" />
        <PanelContainer Name="SepTop" MinHeight="1" HorizontalExpand="True" />

        <!-- Patient Status -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="8">
            <Label Text="{Loc 'autodoc-patient-label'}" FontColorOverride="#33FF33" StyleClasses="monospace" />
            <Label Name="PatientNameLabel"
                   FontColorOverride="#33FF33"
                   StyleClasses="monospace"
                   HorizontalExpand="True" />
            <Label Name="StatusLabel"
                   FontColorOverride="#33FF33"
                   StyleClasses="monospace" />
        </BoxContainer>

        <PanelContainer Name="SepMid1" MinHeight="1" HorizontalExpand="True" />

        <!-- Damage Report -->
        <Label Text="{Loc 'autodoc-diagnostic-report'}"
               FontColorOverride="#33FF33"
               StyleClasses="monospace"
               HorizontalAlignment="Center" />
        <ScrollContainer VerticalExpand="True" HScrollEnabled="False" MinHeight="200">
            <BoxContainer Name="DamageContainer" Orientation="Vertical" SeparationOverride="4" />
        </ScrollContainer>

        <PanelContainer Name="SepMid2" MinHeight="1" HorizontalExpand="True" />

        <!-- Stimulants -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="8">
            <Label Text="{Loc 'autodoc-stimulants-label'}" FontColorOverride="#33FF33" StyleClasses="monospace" />
            <Label Name="StimulantsLabel"
                   FontColorOverride="#55FF55"
                   StyleClasses="monospace"
                   HorizontalExpand="True" />
            <Label Text="{Loc 'autodoc-units'}" FontColorOverride="#33FF33" StyleClasses="monospace" />
        </BoxContainer>

        <!-- Treatment Progress -->
        <BoxContainer Name="ProgressContainer" Orientation="Horizontal" SeparationOverride="8" Visible="False">
            <Label Text="{Loc 'autodoc-treatment-label'}" FontColorOverride="#33FF33" StyleClasses="monospace" />
            <ProgressBar Name="TreatmentProgress" HorizontalExpand="True" MinHeight="20" />
            <Label Name="ProgressPercentLabel" Text="0%" FontColorOverride="#33FF33" StyleClasses="monospace" MinWidth="45" />
        </BoxContainer>

        <PanelContainer Name="SepMid3" MinHeight="1" HorizontalExpand="True" />

        <!-- Door Controls -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="10" HorizontalExpand="True">
            <Button Name="DoorOpenButton"
                    Text="{Loc 'autodoc-door-open-button'}"
                    HorizontalExpand="True"
                    MinWidth="100" />
            <Button Name="DoorCloseButton"
                    Text="{Loc 'autodoc-door-close-button'}"
                    HorizontalExpand="True"
                    MinWidth="100" />
        </BoxContainer>

        <PanelContainer Name="SepMid4" MinHeight="1" HorizontalExpand="True" />

        <!-- Error Message -->
        <Label Name="ErrorLabel"
               FontColorOverride="#FF5555"
               StyleClasses="monospace"
               HorizontalAlignment="Center"
               Visible="False" />

        <PanelContainer Name="SepBottom" MinHeight="1" HorizontalExpand="True" />

        <!-- Buttons -->
        <BoxContainer Orientation="Horizontal" SeparationOverride="10" HorizontalExpand="True">
            <Button Name="EjectBeakerButton"
                    Text="{Loc 'autodoc-eject-beaker'}"
                    HorizontalExpand="True"
                    MinWidth="120" />
            <Button Name="EjectPatientButton"
                    Text="{Loc 'autodoc-eject-patient'}"
                    HorizontalExpand="True"
                    MinWidth="120" />
            <Button Name="StartTreatmentButton"
                    Text="{Loc 'autodoc-start-treatment'}"
                    HorizontalExpand="True"
                    MinWidth="140" />
        </BoxContainer>

        <Label Name="FooterLabel"
               Text="{Loc 'autodoc-footer-ready'}"
               FontColorOverride="#1a5c1a"
               StyleClasses="monospace"
               HorizontalAlignment="Center" />
    </BoxContainer>
</DefaultWindow>
