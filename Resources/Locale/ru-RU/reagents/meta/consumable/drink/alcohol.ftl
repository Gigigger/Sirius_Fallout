reagent-name-booger = козявка
reagent-desc-booger = Фуууу...

reagent-name-brave-bull = храбрый бык
reagent-desc-brave-bull = Это так же эффективно, как и Dutch-Courage!

reagent-name-coconut-rum = кокосовый ром
