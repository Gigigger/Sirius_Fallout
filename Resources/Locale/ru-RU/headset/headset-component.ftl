# Chat window radio wrap (prefix and postfix)
chat-radio-message-wrap = [color=__PH0__]{$channel} [font size=11][color=__PH2__][bold]{$language}[/bold][/color][/font][bold]{$name}[/bold] {$verb}, [font="__PH6__" size=__PH7__][color=__PH2__]"{$message}"[/color][/font][/color]
chat-radio-message-wrap-bold = [color=__PH0__]{$channel} [font size=11][color=__PH2__][bold]{$language}[/bold][/color][/font][bold]{$name}[/bold] {$verb}, [font="__PH6__" size=__PH7__][color=__PH2__][bold]"{$message}"[/bold][/color][/font][/color]
# Misfits Add - emote-style radio wrap (no speech verb, no quotes) e.g. "[Wasteland] Viktoriya laughs over radio."
chat-radio-emote-wrap = [color=__PH0__]{$channel} [bold]{$name}[/bold] {$emote}[/color]

examine-headset-default-channel = Используйте {$prefix} для канала по умолчанию ([color=__PH1__]{$channel}[/color]).

