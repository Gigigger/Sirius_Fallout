execution-verb-name = Выполнять
execution-verb-message = Используйте свое оружие, чтобы казнить кого-нибудь.

# All the below localisation strings have access to the following variables
# attacker (the person committing the execution)
# victim (the person being executed)
# weapon (the weapon used for the execution)

execution-popup-melee-initial-internal = Вы готовите {THE($weapon)} к горлу {$victim}.
execution-popup-melee-initial-external = {$attacker} готовит {POSS-ADJ($attacker)} {$weapon} к горлу {$victim}.
execution-popup-melee-complete-internal = Вы перерезали горло {$victim}!
execution-popup-melee-complete-external = {$attacker} перерезает горло {$victim}!

execution-popup-self-initial-internal = Вы готовите {THE($weapon)} к собственному горлу.
execution-popup-self-initial-external = {$attacker} готовит {POSS-ADJ($attacker)} {$weapon} к собственному горлу.
execution-popup-self-complete-internal = Ты перерезал себе горло!
execution-popup-self-complete-external = {$attacker} перерезает себе горло!